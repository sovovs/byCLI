[
  {
    "_comment": "=== Layer 1: Atomic Operations (10 tasks) ==="
  },
  {
    "name": "v2ex-open-home",
    "steps": [
      "bycli browser open https://v2ex.com/"
    ],
    "judge": {
      "type": "contains",
      "value": "Navigated to"
    }
  },
  {
    "name": "v2ex-state-home",
    "steps": [
      "bycli browser open https://v2ex.com/",
      "bycli browser state"
    ],
    "judge": {
      "type": "matchesPattern",
      "pattern": "\\[\\d+\\]"
    }
  },
  {
    "name": "v2ex-get-title",
    "steps": [
      "bycli browser open https://v2ex.com/",
      "bycli browser eval \"document.title\""
    ],
    "judge": {
      "type": "contains",
      "value": "V2EX"
    }
  },
  {
    "name": "v2ex-click-tab",
    "steps": [
      "bycli browser open https://v2ex.com/",
      "bycli browser eval \"(() => { const a = document.querySelector('a[href=\\\"/?tab=tech\\\"]'); if(a){a.click(); return 'clicked';} return 'not found'; })()\""
    ],
    "judge": {
      "type": "contains",
      "value": "clicked"
    }
  },
  {
    "name": "v2ex-scroll-down",
    "steps": [
      "bycli browser open https://v2ex.com/",
      "bycli browser scroll down --amount 500",
      "bycli browser eval \"window.scrollY > 100 ? 'scrolled' : 'not scrolled'\""
    ],
    "judge": {
      "type": "contains",
      "value": "scrolled"
    }
  },
  {
    "name": "v2ex-get-first-topic-text",
    "steps": [
      "bycli browser open https://v2ex.com/",
      "bycli browser eval \"document.querySelector('a[href^=\\\"/t/\\\"]')?.textContent?.trim()\""
    ],
    "judge": {
      "type": "nonEmpty"
    }
  },
  {
    "name": "v2ex-eval-extract-titles",
    "steps": [
      "bycli browser open https://v2ex.com/",
      "bycli browser eval \"JSON.stringify([...document.querySelectorAll('a[href^=\\\"/t/\\\"]')].slice(0,5).map(a=>a.textContent.trim()).filter(t=>t.length>2))\""
    ],
    "judge": {
      "type": "arrayMinLength",
      "minLength": 3
    }
  },
  {
    "name": "v2ex-get-url",
    "steps": [
      "bycli browser open https://v2ex.com/",
      "bycli browser get url"
    ],
    "judge": {
      "type": "contains",
      "value": "v2ex.com"
    }
  },
  {
    "name": "v2ex-back-navigation",
    "steps": [
      "bycli browser open https://v2ex.com/",
      "bycli browser open https://v2ex.com/go/programmer",
      "bycli browser back",
      "bycli browser get url"
    ],
    "judge": {
      "type": "matchesPattern",
      "pattern": "v2ex\\.com/?$"
    }
  },
  {
    "name": "v2ex-wait-page-load",
